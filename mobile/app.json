{
  "expo": {
    "name": "ZAVARA",
    "slug": "onebohol",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C4951E"
    },
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.zavara.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C4951E"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ZAVARA needs your location to show nearby services."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C4951E",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ZAVARA needs access to your photos to upload images.",
          "cameraPermission": "ZAVARA needs access to your camera to take photos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "28437742-e281-4659-9548-786d8fb0a3cf"
      }
    },
    "owner": "chillzate"
  }
}