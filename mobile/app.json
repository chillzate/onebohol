{
  "expo": {
    "name": "ZAVARA",
    "slug": "zavara",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#1C1710",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1710"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zavara.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C1710"
      },
      "backgroundColor": "#1C1710",
      "package": "com.zavara.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}